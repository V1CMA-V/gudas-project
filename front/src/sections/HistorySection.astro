---
import OurNumbersSection from "./OurNumbersSection.astro";

interface HistoryEntry {
  id: number;
  year: string;
  title: string;
  body: string;
  image: { url: string; alternativeText: string } | null;
}

interface NumberItem {
  id?: number;
  value: string;
  label: string;
  icon?: string;
}

interface HistorySectionProps {
  data: {
    home: HistoryEntry[];
    numbers: NumberItem[];
  };
}

const { data } = Astro.props;
const items = data?.home ?? [];
const baseUrl = import.meta.env.STRAPI_API_URL;
---

<section
  class="history relative isolate overflow-hidden py-[clamp(5rem,12vh,9rem)]"
>
  <div
    class="relative z-[1] mx-auto max-w-[1280px] px-[clamp(1.5rem,5vw,4.5rem)]"
  >
    <!-- header -->
    <header class="mb-[clamp(3rem,8vh,6rem)] max-w-[34rem]">
      <p
        class="mb-5 inline-flex items-center gap-[0.7rem] text-[0.72rem] font-medium uppercase tracking-[0.28em] text-muted-foreground"
      >
        <span class="h-[7px] w-[7px] rounded-full bg-ember"></span>
        Nuestra historia
      </p>
      <h2
        class="text-[clamp(2.4rem,5.5vw,4rem)] leading-[0.95] tracking-[-0.02em] [font-family:Fraunces,serif]"
      >
        Una historia <span class="history__accent italic">en movimiento</span>
      </h2>
    </header>

    <!-- timeline -->
    <ol class="timeline relative m-0 list-none p-0">
      {
        items.map((item: HistoryEntry, i: number) => (
          <li class="t-item relative" style={`--i:${i}`}>
            <span class="t-dot" aria-hidden="true" />
            <div class="t-content pl-[clamp(2rem,5vw,3.5rem)] pb-[clamp(3rem,7vh,5.5rem)]">
              <span class="t-year block text-[clamp(2.4rem,6vw,4.25rem)] leading-none italic [font-family:Fraunces,serif]">
                {item.year}
              </span>
              <h3 class="mt-3 text-[clamp(1.25rem,2.4vw,1.75rem)] font-semibold tracking-tight text-foreground [font-family:Fraunces,serif]">
                {item.title}
              </h3>
              <p class="mt-3 max-w-[44ch] text-[0.98rem] leading-[1.65] text-muted-foreground">
                {item.body}
              </p>
              {item.image && (
                <figure class="t-figure group mt-6 max-w-[34rem] overflow-hidden rounded-[20px]">
                  <img
                    src={baseUrl + item.image.url}
                    alt={item.image.alternativeText || item.title}
                    loading="lazy"
                    class="aspect-[16/10] w-full rounded-[inherit] object-cover object-center transition-transform duration-[900ms] [transition-timing-function:cubic-bezier(0.2,0.8,0.2,1)] group-hover:scale-[1.05]"
                  />
                </figure>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
  <OurNumbersSection data={data.numbers} />

</section>

<style>
  /* atmosphere — warm ember glow, theme-aware */
  .history {
    background: radial-gradient(
      75% 55% at 88% -5%,
      color-mix(in oklch, var(--color-ember) 12%, transparent) 0%,
      transparent 60%
    );
  }

  /* accent word in the heading */
  .history__accent {
    color: transparent;
    background: linear-gradient(
      100deg,
      var(--color-ember-soft),
      var(--color-ember) 65%,
      oklch(0.6 0.22 25)
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* continuous spine running through the markers */
  .timeline::before {
    content: "";
    position: absolute;
    left: 7px;
    top: 0.5rem;
    bottom: 2.5rem;
    width: 1.5px;
    transform: translateX(-50%);
    background: linear-gradient(
      to bottom,
      var(--color-ember) 0%,
      color-mix(in oklch, var(--color-ember) 30%, transparent) 70%,
      transparent 100%
    );
  }

  /* marker */
  .t-dot {
    position: absolute;
    left: 7px;
    top: 0.55rem;
    width: 14px;
    height: 14px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: var(--color-ember);
    box-shadow:
      0 0 0 5px color-mix(in oklch, var(--color-ember) 16%, transparent),
      0 0 18px -2px var(--color-ember);
  }
  .t-dot {
    transition: box-shadow 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .t-item:hover .t-dot {
    box-shadow:
      0 0 0 7px color-mix(in oklch, var(--color-ember) 22%, transparent),
      0 0 26px -2px var(--color-ember);
  }

  /* hito image — framed like the hero, theme-aware */
  .t-figure {
    position: relative;
    border: 1px solid color-mix(in oklch, var(--color-ember) 22%, transparent);
    box-shadow:
      0 30px 60px -28px oklch(0.05 0.02 35 / 0.45),
      0 0 50px -22px color-mix(in oklch, var(--color-ember) 40%, transparent);
    will-change: transform;
  }
  .t-figure::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      200deg,
      transparent 55%,
      color-mix(in oklch, var(--color-ink-deep) 55%, transparent) 100%
    );
  }

  /* oversized ghost year */
  .t-year {
    color: transparent;
    background: linear-gradient(
      120deg,
      var(--color-ember) 0%,
      var(--color-ember-soft) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    opacity: 0.92;
  }

  /* scroll-reveal — only engages once JS marks the section ready,
     so content stays visible without JS */
  .reveal-ready .t-item {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.7s ease,
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 0.12s);
  }
  .reveal-ready .t-item.in {
    opacity: 1;
    transform: none;
  }
  .reveal-ready .timeline::before {
    transform: translateX(-50%) scaleY(0);
    transform-origin: top;
    transition: transform 1.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-ready .timeline.in::before {
    transform: translateX(-50%) scaleY(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-ready .t-item,
    .reveal-ready .timeline::before {
      opacity: 1;
      transform: translateX(-50%) scaleY(1);
      transition: none;
    }
    .reveal-ready .t-item {
      transform: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>(".history");
  const timeline = section?.querySelector<HTMLElement>(".timeline");
  const itemsList = section?.querySelectorAll<HTMLElement>(".t-item");

  if (section && timeline && itemsList?.length) {
    section.classList.add("reveal-ready");

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25, rootMargin: "0px 0px -10% 0px" }
    );

    io.observe(timeline);
    itemsList.forEach((item) => io.observe(item));
  }
</script>
