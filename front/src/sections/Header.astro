---
import { ModeToggle } from "@/components/ModeToggle";

const navigation = [
  {
    label: "Home",
    href: "/",
  },
  {
    label: "About",
    href: "/about",
  },
  {
    label: "Classes",
    href: "/classes",
  },
  {
    label: "Gallery",
    href: "/gallery",
  },
  {
    label: "Contact",
    href: "/contact",
  },
];

const url = Astro.url.pathname;
console.log(url);
const isActive = (href: string) => {
  return url.startsWith(href);
};
---

<header class="bg-background text-foreground fixed top-0 left-0 right-0 z-50">
  <div class="container mx-auto px-4 py-4 flex justify-between items-center">
    <p class="text-2xl font-bold">GUDAS Studio</p>

    <nav class="hidden md:flex gap-4">
      {
        navigation.map((item) => {
          return (
            <a
              href={item.href}
              class:list={[
                "text-sm font-medium hover:scale-105 transition-all",
                isActive(item.href)
                  ? "text-primary font-medium"
                  : "text-foreground font-normal",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
    <ModeToggle />
  </div>
</header>
